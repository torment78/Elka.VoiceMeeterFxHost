<Window x:Class="Elka.VoiceMeeterFxHost.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elka VoiceMeeter FX Host"
        Icon="Assets/VoicemeeterDelay.ico"
        Width="1600"
        Height="900"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="22">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,18">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <StackPanel Orientation="Horizontal">
        <Border Width="62"
                Height="62"
                Margin="0,0,14,0"
                Background="Transparent"
                CornerRadius="8">
          <Image Source="Assets/VoicemeeterDelayIconPreview.png"
                 Stretch="Uniform"
                 RenderOptions.BitmapScalingMode="HighQuality" />
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Elka VoiceMeeter FX Host"
                     FontSize="26"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="MixerTypeTextBlock"
                     Text="Voicemeeter Potato profile"
                     Margin="0,3,0,0"
                     Style="{StaticResource MutedText}" />
        </StackPanel>
      </StackPanel>

      <Border x:Name="EngineStatusBorder"
              Grid.Column="1"
              Background="{StaticResource StatusIdleBrush}"
              CornerRadius="6"
              MinWidth="330"
              MaxWidth="520"
              Padding="12,6"
              VerticalAlignment="Center">
        <TextBlock x:Name="StatusTextBlock"
                   Text="Starting native engine..."
                   FontWeight="SemiBold"
                   TextAlignment="Center"
                   Style="{StaticResource MutedText}" />
      </Border>
    </Grid>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="545" />
        <ColumnDefinition Width="18" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <ScrollViewer Grid.Column="0"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <Border Style="{StaticResource PanelCard}" Margin="0,0,0,16">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="96" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Row="0"
                         Grid.Column="0"
                         Text="Side"
                         VerticalAlignment="Center"
                         FontWeight="SemiBold" />
              <StackPanel Grid.Row="0"
                          Grid.Column="1"
                          Orientation="Horizontal"
                          Margin="0,0,0,12">
                <Button x:Name="InputModeButton"
                        Content="Input"
                        Width="92"
                        Click="InputModeButton_Click" />
                <Button x:Name="OutputModeButton"
                        Content="Output"
                        Width="92"
                        Margin="8,0,0,0"
                        Click="OutputModeButton_Click" />
                <Button x:Name="MainModeButton"
                        Content="Main"
                        Width="92"
                        Margin="8,0,0,0"
                        Click="MainModeButton_Click" />
              </StackPanel>

              <TextBlock Grid.Row="1"
                         Grid.Column="0"
                         Text="I/O"
                         VerticalAlignment="Top"
                         Margin="0,6,0,0"
                         FontWeight="SemiBold" />
              <WrapPanel x:Name="EndpointButtonsPanel"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,0,0,12" />

              <TextBlock Grid.Row="2"
                         Grid.Column="0"
                         Text="Probe"
                         VerticalAlignment="Top"
                         FontWeight="SemiBold" />
              <TextBlock x:Name="ProbeStatusTextBlock"
                         Grid.Row="2"
                         Grid.Column="1"
                         Text="Select an input strip to probe callback stages."
                         Style="{StaticResource MutedText}"
                         TextWrapping="Wrap" />

            </Grid>
          </Border>

          <Border Style="{StaticResource PanelCard}"
                  BorderBrush="{StaticResource RouteAccentBrush}"
                  Margin="0,0,0,16">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="VST Routing"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource RouteAccentBrush}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        x:Name="AddNodeButton"
                        Content="Add Node"
                        Width="92"
                        Style="{StaticResource RouteButton}"
                        Click="AddNodeButton_Click" />
              </Grid>

              <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Content="Add Folder"
                        Width="96"
                        Margin="0,0,8,0"
                        Style="{StaticResource RouteButton}"
                        Click="AddPluginFolderButton_Click"
                        ToolTip="Add a custom VST folder to the scan list." />
                <TextBox x:Name="PluginSearchTextBox"
                         Grid.Column="1"
                         ToolTip="Filter the scanned plugin list by name."
                         TextChanged="PluginSearchTextBox_TextChanged" />
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Margin="8,0,0,0">
                  <Button x:Name="PluginFormatAllButton"
                          Content="All"
                          Width="50"
                          Padding="8,6"
                          Style="{StaticResource RouteButton}"
                          Tag="All"
                          Click="PluginFormatFilterButton_Click" />
                  <Button x:Name="PluginFormatVst3Button"
                          Content="VST3"
                          Width="58"
                          Padding="8,6"
                          Margin="6,0,0,0"
                          Style="{StaticResource RouteButton}"
                          Tag="Vst3"
                          Click="PluginFormatFilterButton_Click" />
                  <Button x:Name="PluginFormatVst2Button"
                          Content="VST2"
                          Width="58"
                          Padding="8,6"
                          Margin="6,0,0,0"
                          Style="{StaticResource RouteButton}"
                          Tag="Vst2"
                          Click="PluginFormatFilterButton_Click" />
                </StackPanel>
                <Button Grid.Column="3"
                        x:Name="ScanButton"
                        Content="Scan"
                        Width="72"
                        Margin="8,0,0,0"
                        Style="{StaticResource RouteButton}"
                        Click="ScanButton_Click" />
              </Grid>

              <Grid Grid.Row="2" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ListBox x:Name="PluginFoldersListBox"
                         Height="68"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         SelectionChanged="PluginFoldersListBox_SelectionChanged"
                         ToolTip="Custom VST folders scanned together with the normal system VST locations." />
                <Button x:Name="RemovePluginFolderButton"
                        Grid.Column="1"
                        Content="Remove"
                        Width="76"
                        Margin="8,0,0,0"
                        VerticalAlignment="Top"
                        Click="RemovePluginFolderButton_Click" />
              </Grid>

              <ListBox x:Name="PluginListBox"
                       Grid.Row="3"
                       Height="132"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       MouseDoubleClick="PluginListBox_MouseDoubleClick" />

              <StackPanel x:Name="VstNodesPanel"
                          Grid.Row="4"
                          Margin="0,10,0,0" />
            </Grid>
          </Border>

          <Border x:Name="CrossRoutingBorder"
                  Style="{StaticResource PanelCard}"
                  BorderBrush="{StaticResource RouteAccentBrush}"
                  Margin="0,0,0,16"
                  Visibility="Collapsed">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="0"
                         Text="Cross Routing"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource RouteAccentBrush}"
                         Margin="0,0,0,8" />
              <TextBlock x:Name="CrossRouteSummaryTextBlock"
                         Grid.Row="1"
                         Style="{StaticResource MutedText}"
                         Margin="0,0,0,10" />
              <StackPanel x:Name="CrossRoutePanel"
                          Grid.Row="2" />
            </Grid>
          </Border>

          <Border Style="{StaticResource PanelCard}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Row="0"
                         Grid.Column="0"
                         Text="Tools"
                         FontSize="18"
                         FontWeight="SemiBold" />
              <Button Grid.Row="0"
                      Grid.Column="1"
                      Content="Single Ping"
                      Width="112"
                      Click="SinglePingButton_Click" />

              <Grid Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,12,0,8">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="VbanEnableCheckBox"
                          Grid.Row="0"
                          Grid.Column="0"
                          Content="VBAN Text"
                          VerticalAlignment="Center"
                          Foreground="{StaticResource VbanAccentBrush}"
                          ToolTip="Listen for MacroButtons VBAN-TEXT commands for this app." />
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="Port"
                           Margin="12,0,6,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource MutedText}" />
                <TextBox x:Name="VbanPortTextBox"
                         Grid.Row="0"
                         Grid.Column="2"
                         Width="72"
                         HorizontalAlignment="Left"
                         Text="6981"
                         ToolTip="UDP port used by the VBAN-TEXT command listener." />
                <Button Grid.Row="0"
                        Grid.Column="3"
                        Content="VFX Commands"
                        Width="124"
                        Margin="8,0,0,0"
                        Click="OpenVfxCommandsButton_Click" />

                <StackPanel Grid.Row="1"
                            Grid.ColumnSpan="4"
                            Orientation="Horizontal"
                            Margin="0,8,0,0">
                  <TextBlock Text="Stream"
                             Margin="0,0,6,0"
                             VerticalAlignment="Center"
                             Style="{StaticResource MutedText}" />
                  <TextBox x:Name="VbanStreamTextBox"
                           Width="120"
                           Text="Command1"
                           ToolTip="VBAN-TEXT stream name sent by MacroButtons." />
                  <CheckBox x:Name="VbanLocalOnlyCheckBox"
                            Content="Local only"
                            IsChecked="True"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="Only accept VBAN text commands from this PC." />
                  <TextBlock x:Name="VbanStatusTextBlock"
                             Text="VBAN off"
                             Margin="12,2,0,0"
                             VerticalAlignment="Center"
                             Style="{StaticResource MutedText}" />
                </StackPanel>
              </Grid>

              <TextBlock x:Name="RouteSummaryTextBlock"
                         Grid.Row="2"
                         Grid.ColumnSpan="2"
                         Margin="0,4,0,8"
                         Style="{StaticResource MutedText}" />
              <TextBox x:Name="LogTextBox"
                       Grid.Row="3"
                       Grid.ColumnSpan="2"
                       Height="110"
                       FontFamily="Consolas"
                       FontSize="13"
                       IsReadOnly="True"
                       TextWrapping="Wrap"
                       VerticalScrollBarVisibility="Auto" />
            </Grid>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Border Grid.Column="2"
              Style="{StaticResource PanelCard}"
              Padding="0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Grid Grid.Row="0" Margin="14,12,14,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="RoutingCanvasTitleTextBlock"
                       Text="Routing Canvas"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource RouteAccentBrush}" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
              <Button x:Name="ChannelsWorkspaceButton"
                      Content="Channels"
                      Width="92"
                      Style="{StaticResource RouteButton}"
                      Click="ChannelsWorkspaceButton_Click" />
              <Button x:Name="VstWorkspaceButton"
                      Content="VST"
                      Width="74"
                      Margin="8,0,0,0"
                      Style="{StaticResource RouteButton}"
                      Click="VstWorkspaceButton_Click" />
              <Button Content="Save"
                      Width="74"
                      Margin="8,0,0,0"
                      Click="SaveButton_Click" />
              <Button Content="Refresh"
                      Width="74"
                      Margin="8,0,0,0"
                      Click="RefreshCanvasButton_Click" />
            </StackPanel>
          </Grid>

          <Border x:Name="VstWorkspaceView"
                  Grid.Row="1"
                  Margin="14,0,14,14"
                  Background="{StaticResource FieldBrush}"
                  BorderBrush="{StaticResource SubtleBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="6">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
              <Canvas x:Name="RoutingCanvas"
                      Width="980"
                      Height="920"
                      Background="{StaticResource FieldBrush}"
                      MouseMove="RoutingCanvas_MouseMove"
                      MouseLeftButtonUp="RoutingCanvas_MouseLeftButtonUp" />
            </ScrollViewer>
          </Border>

          <Grid x:Name="ChannelsWorkspaceView"
                Grid.Row="1"
                Margin="14,0,14,14"
                Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="12" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource FieldBrush}"
                    BorderBrush="{StaticResource SubtleBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="ChannelStripTitleTextBlock"
                           Grid.Row="0"
                           Text="Channels"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource RouteAccentBrush}"
                           Margin="0,0,0,8" />
                <ScrollViewer Grid.Row="1"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                  <StackPanel x:Name="ChannelStripPanel"
                              Orientation="Horizontal"
                              MinHeight="248" />
                </ScrollViewer>
              </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource FieldBrush}"
                    BorderBrush="{StaticResource SubtleBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
              <ScrollViewer HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                <Canvas x:Name="CrossRouteCanvas"
                        Width="980"
                        Height="560"
                        Background="{StaticResource FieldBrush}"
                        MouseMove="CrossRouteCanvas_MouseMove"
                        MouseLeftButtonUp="CrossRouteCanvas_MouseLeftButtonUp" />
              </ScrollViewer>
            </Border>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
