<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>$(RepoRoot)\artifacts\publish\ElkaVoiceMeeterFxHost\win-x64\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <ElkaCreateReleaseArtifacts>true</ElkaCreateReleaseArtifacts>
    <ElkaUploadGitHubRelease>true</ElkaUploadGitHubRelease>
    <GitHubRepository Condition="'$(GitHubRepository)' == ''">torment78/Elka.VoiceMeeterFxHost</GitHubRepository>
    <GitHubReleaseTag Condition="'$(GitHubReleaseTag)' == ''">v$(Version)</GitHubReleaseTag>
    <ReleaseDir>$(RepoRoot)\artifacts\release\</ReleaseDir>
    <PublishOutputDir>$(PublishDir)</PublishOutputDir>
    <PublishedExePath>$(PublishOutputDir)Elka.VoiceMeeterFxHost.App.exe</PublishedExePath>
    <ReleaseExePath>$(ReleaseDir)ElkaVoiceMeeterFxHost.exe</ReleaseExePath>
    <ReleaseZipPath>$(ReleaseDir)ElkaVoiceMeeterFxHost-$(RuntimeIdentifier)-framework-dependent.zip</ReleaseZipPath>
    <ReleaseUploadLogPath>$(ReleaseDir)github-upload.log</ReleaseUploadLogPath>
  </PropertyGroup>
</Project>
